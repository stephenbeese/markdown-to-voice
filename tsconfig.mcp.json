{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist-mcp",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["mcp/**/*.ts", "src/lib/**/*.ts"]
}
